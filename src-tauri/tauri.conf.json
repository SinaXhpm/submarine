{
  "productName": "omni",
  "version": "0.1.0",
  "identifier": "com.omni.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
"app": {
    "windows": [
      {
        "title": "Omni",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}